# ============================================================
# VERUS Eléctrico — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ============================================================

# Base de datos PostgreSQL
# Opción A — PostgreSQL local (para prueba):
DATABASE_URL="postgresql://postgres:password@localhost:5432/verus_electrico?schema=public"

# Opción B — Azure PostgreSQL Flexible (producción, requiere VPN o acceso directo):
# DATABASE_URL="postgresql://verus_electrico_app:<password>@pg-ghi-apps-dev.postgres.database.azure.com:5432/verus_electrico?sslmode=require&schema=public"

# Auth.js v5
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes"

# Microsoft Entra ID (Azure AD) — dejar vacíos para usar login de desarrollo
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="aa0adef3-bffb-4b93-86ef-c77158ee71e5"

# URL base de la aplicación
NEXTAUTH_URL="http://localhost:3000"

# Entorno
NODE_ENV="development"
